<!DOCTYPE html>

<html lang="en">
  <head>
    @if{isFragment || pageTemplate == null}
      <title>YouPipe</title>
    @end{}

    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

    <!-- common css rules -->
    <style>
      :root {
        --theme-primary: #952922;
        --theme-secondary: #252024;
        --text-primary: white;
        --text-secondary: lightgrey;

        --space-primary: 5px;
      }

      .material-symbols-outlined {
        vertical-align: text-bottom;
      }

      /* sitewide colours */
      * {
        color: var(--text-primary);
      }
      body {
        margin: 0px;
        background-color: var(--theme-secondary);
      }
      form {
        input, button, select {
          &, & * {
            color: revert;
          }
        }
      }

      /* layout */
      nav, main, footer {
        padding: var(--space-primary); 
      }
      nav {
        background-color: var(--theme-primary);

        display: flex;
        justify-content: space-between;

        @media @{isMobile} {
          flex-direction: column;
        }

        > div {
          flex: 2 0;
          display: flex;
          justify-content: space-between;
          align-items: center;
        }

        > form {
          display: flex;
        }
      }

      footer section {
        display: flex;

        a {
          margin-right: var(--space-primary);
        }
      }

      /* common template pattern */
      .tab-container {
        .tabs {
          display: flex;
          justify-content: stretch;
          margin-bottom: var(--space-primary);

          .tab {
            flex: 1;

            button {
              width: 100%;
            }
          }
        }
      }

      /* search item list */
      .search-results {
        display: flex;
        flex-direction: row;
        flex-wrap: wrap;
        justify-content: space-between;

        @media @{isMobile} {
          flex-direction: column;
        }
      }

      .search-result {
        display: flex;
        flex-direction: column;
        margin-bottom: var(--space-primary);
        width: 250px;
        height: 300px;

        @media @{isMobile} {
          flex-direction: row;
          height: 150px;
          width: 100%;
        }
      }

      .search-result img {
        background-position: center center;
        /*flex: 1 0 20%;*/
        /*height: 100px;*/
        @media @{isMobile} {
          flex: 1 0 20%;
        }
      }

      .search-result .details {
        /*flex: 5 0 80%;*/

        display: flex;
        flex-direction: column;

        @media @{isMobile} {
          flex: 2 0 80%;

          align-self: center;
        }

        .secondary-details, .secondary-details * {
          color: var(--text-secondary);
        }
      }
    </style>
  </head>
  <body hx-target="main" hx-swap="innerHTML show:no-scroll" hx-boost="true" hx-indicator="#loading-indicator">
    <nav>
      <div>
        <div class="nav-options">
          <b>YouPipe</b>
          <!--<a href="/apis/user/feed">Feed</a>-->
          <!--<a href="/apis/user/playlists">Playlists</a>-->
          <a href="/subscriptions">Subscriptions</a>
          <a href="/settings">Settings</a>
        </div>
        <div id="loading-indicator" class="htmx-indicator">Loading...</div>
      </div>
      <form action="/search" target="_SELF" method="GET">
        <input name="query" type="search" value="@{query}" />
        <button type="submit">
          @{templateUtility.icon("search", "Search")}
        </button>
      </form>
    </nav>
    <main hx-history-elt>
      @if{!isFragment && pageTemplate != null}
        @{templateLoader.load(pageTemplate)}
      @else{}
        <p>Served from vert.x!</p>
      @end{}
    </main>
    <footer>
      <hr />
      <p>Copyright (C) 2026 Gregory Norton</p>
      <section>
        <a href="https://github.com/stuffandahalf/youpipe" target="_BLANK">GitHub</a>
        <a href="https://github.com/TeamNewPipe/NewPipeExtractor" target="_BLANK">NewPipeExtractor</p>
      </section>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js"></script>
  </body>
</html>
