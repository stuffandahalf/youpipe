<!DOCTYPE html>

<html lang="en">
  <head>
    @if{isFragment || pageTemplate == null}
      <title>YouPipe</title>
    @end{}

    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- common css rules -->
    <style>
      nav {
        display: flex;
        justify-content: space-between;
      }

      .tab-container .tabs {
        display: flex;
      }
    </style>
  </head>
  <body hx-target="main" hx-swap="innerHTML show:no-scroll" hx-boost="true">
    <nav>
      <div>
        <b>YouPipe</b>
        <!--<a href="/apis/user/feed">Feed</a>-->
        <!--<a href="/apis/user/playlists">Playlists</a>-->
        <a href="/subscriptions">Subscriptions</a>
        <a href="/settings">Settings</a>
      </div>
      <form action="/search" target="_SELF" method="GET">
        <input name="query" type="search" value="@{query}" />
        <button type="submit">search</button>
      </form>
    </nav>
    <main hx-history-elt>
      @if{!isFragment && pageTemplate != null}
        @include{pageTemplate}
      @else{}
        <p>Served from vert.x!</p>
      @end{}
    </main>
    <footer>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js"></script>
  </body>
</html>
