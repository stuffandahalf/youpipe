<p>ALL SUBSCRIPTIONS (Last Updated @{feedLastUpdated})</p>
<form action="@{basePath}/refresh">
  <button type="submit">Refresh</button>
</form>

@if{failures.size() > 0}
<div>
  <b>Failed to retrieve</b>
  <ul>
    @foreach{failure : failures}
      <li>@{failure.name}</li>
    @end{}
  </ul>
</div>
@end{}

@{templateLoader.load("common/listItems")}
